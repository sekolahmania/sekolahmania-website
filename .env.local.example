# SekolahMania — Convex environment configuration
# Copy this file to ".env.local" and fill in your real values.
# NEVER commit .env.local to Git (it is already in .gitignore).

# ── Self-hosted Convex (Docker / Fly / Railway) ──────────────────────────────
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210

# IMPORTANT: paste the FULL admin key including the "convex-self-hosted|" prefix.
# Generate it with:  docker compose exec backend ./generate_admin_key.sh
# Omitting the prefix causes: 401 Unauthorized: BadAdminKey
CONVEX_SELF_HOSTED_ADMIN_KEY=convex-self-hosted|REPLACE_WITH_YOUR_FULL_KEY

# ── Cloud Convex (convex.dev) — used instead of the two vars above ───────────
# CONVEX_DEPLOYMENT=dev:your-deployment-name
